# ──────────────────────────────────────────────────────────────────────
# SmileyChat configuration
# ──────────────────────────────────────────────────────────────────────
# This file ships as the on-boot template. SmileyChat auto-creates a real
# `.env` from this template the first time the server starts so you have
# somewhere to drop your settings. Edit the real `.env` (next to this
# file) rather than .env.example.
#
# Almost every setting in here hot-reloads: edit `.env`, save, and the
# change takes effect within ~2 seconds, no restart required. The
# exceptions (port, host, CSRF secret) are flagged with [restart].

# ── Server binding ─────────────────────────────────────────────────────

# Hostname the server binds to. [restart]
#   0.0.0.0   → all IPv4 interfaces. This is the default. Reachable from
#               LAN, Tailscale, and Docker. The safe-by-default lockdown
#               refuses non-loopback requests until you set Basic Auth
#               or an IP allowlist below, so this is safe out of the box.
#   ::        → all IPv4 + IPv6 interfaces.
#   127.0.0.1 → loopback only. Hardest lockdown: nothing on the network
#               can reach SmileyChat at all.
# SMILEYCHAT_HOST=0.0.0.0

# Port the server listens on. [restart]
# (legacy alias: SMILEYCHAT_API_PORT, still honored)
# SMILEYCHAT_PORT=4173

# Frontend dev-server port (only used by `bun run dev`). [restart]
# SMILEYCHAT_FRONTEND_PORT=5173

# ── CSRF & cross-origin browser provenance ─────────────────────────────

# Comma-separated browser origins that may make state-changing requests.
# Loopback and configured private-network origins are auto-trusted, so
# only add to this list when serving SmileyChat behind a reverse proxy
# or under a DNS name. Origins only: `scheme://host:port`, no paths.
# Example: https://chat.example.com,http://192.168.1.20:4173
# SMILEYCHAT_TRUSTED_ORIGINS=

# Optional override for the CSRF token signing secret. [restart]
# When unset, a 32-byte random secret is generated and persisted to
# userData/settings/csrf-secret.json on first boot.
# SMILEYCHAT_CSRF_SECRET=

# ── HTTP Basic Auth ────────────────────────────────────────────────────
# Set BOTH user and pass to require username/password on every request
# from non-loopback, non-allowlisted IPs. The browser shows a native
# password prompt. Pair with HTTPS (reverse proxy) when exposing over
# the internet. Basic Auth sends credentials on every request, just
# base64-encoded.
# SMILEYCHAT_BASIC_AUTH_USER=
# SMILEYCHAT_BASIC_AUTH_PASS=

# String shown in the browser's password prompt.
# SMILEYCHAT_BASIC_AUTH_REALM=SmileyChat

# ── IP allowlist ───────────────────────────────────────────────────────
# Comma-separated IPs or CIDRs. When set, only loopback + the listed
# ranges may reach the server. Loopback is always allowed so you can
# never lock yourself out of local access.
# Example: 192.168.1.0/24,10.0.0.5,2001:db8::/32
# SMILEYCHAT_IP_ALLOWLIST=

# Set to false to keep the list above on disk but temporarily disable
# enforcement (useful when debugging a "why can't I connect" issue).
# SMILEYCHAT_IP_ALLOWLIST_ENABLED=true

# ── Safe-by-default remote lockdown ────────────────────────────────────
# When no Basic Auth credentials are set, SmileyChat refuses non-loopback
# requests and shows a friendly setup page. These flags opt back into
# the legacy "anyone can connect" behaviour:

# Allow LAN/Docker/Tailscale/IPv6-ULA clients without auth. Use this on
# a fully trusted home network where you accept that anyone on the
# network can read all your chats and API keys.
# SMILEYCHAT_ALLOW_UNAUTHENTICATED_PRIVATE_NETWORK=false

# Allow public-internet clients without auth. DO NOT enable this unless
# SmileyChat sits behind a reverse proxy that does its own auth.
# SMILEYCHAT_ALLOW_UNAUTHENTICATED_REMOTE=false

# Override the default "trusted private networks" CIDR list. When set,
# REPLACES the built-in defaults (RFC 1918, RFC 6598 CGNAT, RFC 3927
# link-local, RFC 4193 IPv6 ULA, RFC 4291 IPv6 link-local).
# SMILEYCHAT_TRUSTED_PRIVATE_NETWORKS=

# ── Tailscale & Docker bypass ──────────────────────────────────────────
# Treat Tailscale CGNAT (100.64.0.0/10) and Docker bridge (172.16.0.0/12)
# traffic as loopback-trusted by default. Skips both the IP allowlist
# and Basic Auth. Set to false to require auth from those networks too.
# SMILEYCHAT_BYPASS_AUTH_TAILSCALE=true
# SMILEYCHAT_BYPASS_AUTH_DOCKER=true

# ── Rate limiting ──────────────────────────────────────────────────────
# Fixed-window per-IP rate limit on /api/*. The default applies to every
# endpoint; a few hot routes (import, avatar upload, CSRF token) get
# tighter buckets configured in code.
# SMILEYCHAT_RATE_LIMIT_ENABLED=true
# SMILEYCHAT_RATE_LIMIT_DEFAULT=600

# ── Privileged endpoints (admin secret) ────────────────────────────────
# Optional second factor for any destructive endpoint a plugin or future
# core feature might expose via `requirePrivilegedAccess`. Sent as
# `X-SmileyChat-Admin-Secret: <value>` header.
# SMILEYCHAT_ADMIN_SECRET=

# By default loopback callers skip the admin-secret check (you can run
# `curl localhost/...` against your own machine without juggling a secret).
# Set this true to require the admin secret even from loopback.
# SMILEYCHAT_REQUIRE_ADMIN_SECRET_ON_LOOPBACK=false

# ── Outbound fetch policy (for plugins) ────────────────────────────────
# Plugins that call `safeFetch` from the server side will refuse to
# resolve to loopback / RFC 1918 / metadata / reserved IPs by default.
# Flip this true to let plugins fetch local URLs (e.g. a self-hosted
# embedding service on 127.0.0.1). Note: SmileyChat itself does not call
# `safeFetch` today, because LLM provider calls go browser→provider direct.
# SMILEYCHAT_PLUGINS_ALLOW_OUTBOUND_FETCH=false

# ── Logging ────────────────────────────────────────────────────────────
# Log verbosity. Currently informational, emitted by the security
# middleware so you can see auth lockdowns, allowlist denials, rate-limit
# warns, etc. Values: error, warn, info, debug.
# SMILEYCHAT_LOG_LEVEL=info
