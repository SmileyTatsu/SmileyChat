{
    "name": "smileychat",
    "private": true,
    "version": "0.0.4",
    "type": "module",
    "scripts": {
        "dev": "concurrently -n web,api \"bun run dev:web\" \"bun run dev:api\"",
        "dev:web": "bun --bun vite --host 127.0.0.1",
        "dev:api": "bun --watch --no-clear-screen server/index.ts",
        "build": "bun --bun tsc && bun --bun vite build",
        "format": "prettier --write .",
        "test": "bun test",
        "start": "bun server/index.ts",
        "preview": "bun --bun vite preview --host 127.0.0.1",
        "typecheck": "bun --bun tsc --noEmit"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@preact/preset-vite": "^2.10.5",
        "@preact/signals": "^2.9.2",
        "adm-zip": "^0.5.17",
        "clsx": "^2.1.1",
        "lucide-preact": "^1.21.0",
        "preact": "^10.29.2"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.1",
        "@types/adm-zip": "^0.5.8",
        "@types/node": "^25.9.4",
        "bun-types": "^1.3.14",
        "concurrently": "^10.0.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.3.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
    }
}
